#!/usr/bin/env bash
# Sublet installer. Intended to be run either directly from a clone
# (`bin/install`) or piped from curl:
#
#   curl -fsSL https://raw.githubusercontent.com/JumpstartLab/sublet/master/bin/install | bash
#
# Flow: clone if needed -> mint a long-lived OAuth token via
# `claude setup-token` -> write .env -> `docker compose up`.

set -euo pipefail

REPO_URL="${SUBLET_REPO_URL:-https://github.com/JumpstartLab/sublet.git}"
REPO_DIR="${SUBLET_REPO_DIR:-sublet}"
PORT="${SUBLET_PORT:-4001}"

# When piped from curl, stdin is the script itself. Rebind to the TTY so
# `claude setup-token` (and any prompts we add) can still read user input.
if [ ! -t 0 ] && [ -e /dev/tty ]; then
  exec < /dev/tty
fi

say() { printf '\n\033[1;36m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*" >&2; }
die() { printf '\033[1;31mxx\033[0m %s\n' "$*" >&2; exit 1; }

require() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1 ($2)"
}

say "Checking prerequisites"
require git "install git: https://git-scm.com/downloads"
require docker "install Docker Desktop: https://www.docker.com/products/docker-desktop/"
require claude "install Claude Code: https://docs.claude.com/en/docs/claude-code"
docker info >/dev/null 2>&1 || die "Docker daemon is not running — start Docker Desktop and retry"

# Figure out where we're running. If the current directory looks like a
# Sublet checkout (has app.rb + docker-compose.yml), reuse it. Otherwise,
# clone into ./$REPO_DIR.
if [ -f "app.rb" ] && [ -f "docker-compose.yml" ]; then
  say "Using current directory as Sublet checkout"
elif [ -d "$REPO_DIR/.git" ]; then
  say "Found existing $REPO_DIR checkout, using it"
  cd "$REPO_DIR"
else
  say "Cloning $REPO_URL into ./$REPO_DIR"
  git clone --depth 1 "$REPO_URL" "$REPO_DIR"
  cd "$REPO_DIR"
fi

# Mint a token unless .env already has one.
if [ -f ".env" ] && grep -q '^CLAUDE_OAUTH_TOKEN=.' .env; then
  say ".env already has CLAUDE_OAUTH_TOKEN — skipping setup-token"
else
  say "Running 'claude setup-token' to mint a long-lived OAuth token"
  echo "   (a browser window will open; copy the token it prints when done)"
  # Show setup-token output live AND capture it so we can extract the token.
  token_output="$(claude setup-token | tee /dev/tty)"
  token="$(printf '%s\n' "$token_output" | grep -oE 'sk-ant-oat01-[A-Za-z0-9_-]+' | head -n1 || true)"
  if [ -z "$token" ]; then
    warn "Could not auto-detect the token in setup-token output."
    printf 'Paste the token manually: '
    read -r token
  fi
  [ -n "$token" ] || die "No token captured — aborting"

  # Preserve any pre-existing .env lines other than CLAUDE_OAUTH_TOKEN.
  if [ -f ".env" ]; then
    grep -v '^CLAUDE_OAUTH_TOKEN=' .env > .env.tmp || true
    mv .env.tmp .env
  else
    : > .env
  fi
  printf 'CLAUDE_OAUTH_TOKEN=%s\n' "$token" >> .env
  unset token token_output
  say "Wrote CLAUDE_OAUTH_TOKEN to .env"
fi

say "Building and starting the container"
docker compose up -d --build

say "Waiting for Sublet to come up on :$PORT"
for _ in $(seq 1 30); do
  if curl -fsS "http://localhost:$PORT/health" >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

if curl -fsS "http://localhost:$PORT/health" >/dev/null 2>&1; then
  say "Sublet is running at http://localhost:$PORT"
  echo "   Try it:"
  echo "     curl -s http://localhost:$PORT/v1/messages \\"
  echo "       -H 'content-type: application/json' \\"
  echo "       -d '{\"model\":\"claude-haiku-4-5-20251001\",\"max_tokens\":50,\"messages\":[{\"role\":\"user\",\"content\":\"Say hi.\"}]}'"
else
  die "Sublet did not become healthy in 30s — check 'docker compose logs'"
fi
